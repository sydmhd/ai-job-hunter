# ─────────────────────────────────────────────
#  AI JOB HUNTER — Environment Configuration
# ─────────────────────────────────────────────

# OpenAI / LLM
OPENAI_API_KEY=sk-...

# Airtable
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_NAME=JobTracker

# Gmail OAuth (path to downloaded credentials JSON from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json
SENDER_EMAIL=you@gmail.com

# LinkedIn
LINKEDIN_EMAIL=you@linkedin.com
LINKEDIN_PASSWORD=yourpassword

# Naukri (optional)
NAUKRI_EMAIL=you@email.com
NAUKRI_PASSWORD=yourpassword

# Candidate Info (used in outreach templates)
CANDIDATE_NAME=Your Full Name
CANDIDATE_LINKEDIN=https://linkedin.com/in/yourprofile
CANDIDATE_PHONE=+91-XXXXXXXXXX
